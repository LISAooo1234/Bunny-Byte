provider = "deepseek"

[providers.openai]
protocol = "openai"
api_key = "your-api-key"
base_url = "https://api.openai.com/v1"
model = "gpt-5.4"

[providers.anthropic]
protocol = "anthropic"
api_key = "your-api-key"
base_url = "https://api.anthropic.com"
model = "claude-sonnet-4-6"

[providers.deepseek]
protocol = "anthropic"
api_key = "your-api-key"
base_url = "https://api.deepseek.com/anthropic"
model = "deepseek-v4-pro"

[sandbox]
mode = "off"
backend = "auto"
workspace_write = true
excluded_commands = []

[sandbox.filesystem]
extra_readonly_paths = []
deny_read = []
deny_write = []
